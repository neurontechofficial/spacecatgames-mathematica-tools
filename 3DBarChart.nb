Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Published", " ", "CSV", " ", "link"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "sheetURL", 
     "=", "\"\<https://docs.google.com/spreadsheets/d/e/2PACX-1vTf-\
6AlCge2OKAs4JuAPi5cPtJWmGqjMy27zGyTheWlWiToV4MxwCel0E_YiMiK11QpF69v-EW8bi78/\
pub?output=csv\>\""}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Import", " ", "the", " ", "data"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"sheetURL", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Separate", " ", "headers", " ", "and", " ", "values"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"values", "=", 
     RowBox[{"Rest", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Clean", " ", "and", " ", "convert", " ", "total", " ", "plays", " ", 
      "to", " ", "numbers"}], ",", 
     RowBox[{
      RowBox[{"replace", " ", 
       RowBox[{"missing", "/", "non"}]}], "-", 
      RowBox[{"numeric", " ", "with", " ", "0"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanValues", "=", 
     RowBox[{"values", "/.", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"title_", ",", "count_"}], "}"}], ":>", 
       RowBox[{"{", 
        RowBox[{"title", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"StringQ", "[", "count", "]"}], "&&", 
            RowBox[{"StringMatchQ", "[", 
             RowBox[{"count", ",", "NumberString"}], "]"}]}], ",", 
           RowBox[{"ToExpression", "[", "count", "]"}], ",", "0"}], "]"}]}], 
        "}"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "How", " ", "many", " ", "top", " ", "games", " ", "to", " ", "show"}], 
    "*)"}], 
   RowBox[{
    RowBox[{"topN", "=", "20"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sort", " ", "cleanValues", " ", "descending", " ", "by", " ", "total", " ",
      "plays"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sortedValues", "=", 
     RowBox[{"Reverse", "@", 
      RowBox[{"SortBy", "[", 
       RowBox[{"cleanValues", ",", "Last"}], "]"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Take", " ", "top", " ", "N", " ", "games"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"topGames", "=", 
     RowBox[{"sortedValues", "[", 
      RowBox[{"[", 
       RowBox[{";;", 
        RowBox[{"Min", "[", 
         RowBox[{"topN", ",", 
          RowBox[{"Length", "[", "sortedValues", "]"}]}], "]"}]}], "]"}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3", "D", " ", "bar", " ", "chart", " ", "with", " ", "tooltips"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tooltip", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"ColorData", "[", "\"\<Pastel\>\"", "]"}], "[", 
            RowBox[{"i", "/", 
             RowBox[{"Length", "[", "topGames", "]"}]}], "]"}], ",", 
           RowBox[{"Cuboid", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"i", ",", "0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"i", "+", "0.8"}], ",", "1", ",", 
               RowBox[{"topGames", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}]}], "]"}]}], 
          "}"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"topGames", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", "\"\<: \>\"", ",", 
            RowBox[{"topGames", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}]}], "]"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "topGames", "]"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"Axes", "->", "True"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Rank\>\"", ",", "\"\<\>\"", ",", "\"\<Total Plays\>\""}], 
       "}"}]}], ",", 
     RowBox[{"Boxed", "->", "False"}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Top Played Games (3D with Tooltips)\>\""}], ",", 
     
     RowBox[{"ImageSize", "->", "Large"}]}], "]"}], 
   "\[IndentingNewLine]"}]}]], "Input",
