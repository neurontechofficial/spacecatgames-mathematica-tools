Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Published", " ", "CSV", " ", "link"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "sheetURL", 
     "=", "\"\<https://docs.google.com/spreadsheets/d/e/2PACX-1vTf-\
6AlCge2OKAs4JuAPi5cPtJWmGqjMy27zGyTheWlWiToV4MxwCel0E_YiMiK11QpF69v-EW8bi78/\
pub?output=csv\>\""}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Import", " ", "the", " ", "data"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"sheetURL", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Separate", " ", "headers", " ", "and", " ", "values"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"values", "=", 
     RowBox[{"Rest", "[", "data", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Clean", " ", "and", " ", "convert", " ", "total", " ", "plays", " ", 
      "to", " ", "numbers"}], ",", 
     RowBox[{
      RowBox[{"replace", " ", 
       RowBox[{"missing", "/", "non"}]}], "-", 
      RowBox[{"numeric", " ", "with", " ", "0"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanValues", "=", 
     RowBox[{"values", "/.", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"title_", ",", "count_"}], "}"}], ":>", 
       RowBox[{"{", 
        RowBox[{"title", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"StringQ", "[", "count", "]"}], "&&", 
            RowBox[{"StringMatchQ", "[", 
             RowBox[{"count", ",", "NumberString"}], "]"}]}], ",", 
           RowBox[{"ToExpression", "[", "count", "]"}], ",", "0"}], "]"}]}], 
        "}"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Sort", " ", "descending", " ", "by", " ", "total", " ", "plays"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanValues", "=", 
     RowBox[{"Reverse", "@", 
      RowBox[{"SortBy", "[", 
       RowBox[{"cleanValues", ",", "Last"}], "]"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Build", " ", "BubbleChart", " ", "with", " ", "hover", " ", "tooltips"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{"BubbleChart", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tooltip", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"cleanValues", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", 
           RowBox[{"cleanValues", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"cleanValues", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", "\"\<: \>\"", ",", 
            RowBox[{"cleanValues", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], "]"}]}], "]"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "cleanValues", "]"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Total Plays per Game\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
