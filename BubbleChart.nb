Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Published", " ", "CSV", " ", "link"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "sheetURL", 
     "=", "\"\<https://docs.google.com/spreadsheets/d/e/2PACX-1vTf-\
6AlCge2OKAs4JuAPi5cPtJWmGqjMy27zGyTheWlWiToV4MxwCel0E_YiMiK11QpF69v-EW8bi78/\
pub?output=csv\>\""}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Import", " ", "data"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"sheetURL", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Separate", " ", "headers", " ", "and", " ", "values"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"headers", "=", 
     RowBox[{"First", "[", "data", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"values", "=", 
     RowBox[{"Rest", "[", "data", "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Convert", " ", "total", " ", "plays", " ", "to", " ", "numbers"}], ",", 
     
     RowBox[{
      RowBox[{"replace", " ", 
       RowBox[{"missing", "/", "non"}]}], "-", 
      RowBox[{"numeric", " ", "with", " ", "0"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanValues", "=", 
     RowBox[{"values", "/.", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"title_", ",", "count_"}], "}"}], ":>", 
       RowBox[{"{", 
        RowBox[{"title", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"StringQ", "[", "count", "]"}], "&&", 
            RowBox[{"StringMatchQ", "[", 
             RowBox[{"count", ",", "NumberString"}], "]"}]}], ",", 
           RowBox[{"ToExpression", "[", "count", "]"}], ",", "0"}], "]"}]}], 
        "}"}]}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Optional", ":", 
     RowBox[{
     "sort", " ", "descending", " ", "by", " ", "total", " ", "plays"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cleanValues", "=", 
     RowBox[{"Reverse", "@", 
      RowBox[{"SortBy", "[", 
       RowBox[{"cleanValues", ",", "Last"}], "]"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Show", " ", "top", " ", "N", " ", "games", " ", "for", " ", 
     "readability"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"topN", "=", "20"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"BarChart", "[", 
    RowBox[{
     RowBox[{"cleanValues", "[", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{";;", 
         RowBox[{"Min", "[", 
          RowBox[{"topN", ",", 
           RowBox[{"Length", "[", "cleanValues", "]"}]}], "]"}]}], ",", "2"}],
        "]"}], "]"}], ",", 
     RowBox[{"ChartLabels", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"cleanValues", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{";;", 
            RowBox[{"Min", "[", 
             RowBox[{"topN", ",", 
              RowBox[{"Length", "[", "cleanValues", "]"}]}], "]"}]}], ",", 
           "1"}], "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"Rotate", "[", 
          RowBox[{"#", ",", 
           RowBox[{"45", " ", "Degree"}]}], "]"}], "&"}]}], "]"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Top Games by Total Plays\>\""}], ",", 
     RowBox[{"ImageSize", "->", "Large"}], ",", 
     RowBox[{"ChartStyle", "->", "\"\<Pastel\>\""}], ",", 
     RowBox[{"BarSpacing", "->", "0.5"}]}], "]"}]}]}]], "Input",
