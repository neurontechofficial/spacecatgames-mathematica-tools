Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sorted", "=", 
    RowBox[{"Reverse", "@", 
     RowBox[{"SortBy", "[", 
      RowBox[{"cleanValues", ",", "Last"}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"titles", "=", 
    RowBox[{"sorted", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"plays", "=", 
   RowBox[{"Replace", "[", 
    RowBox[{
     RowBox[{"sorted", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"_Missing", "->", "0"}], ",", 
       RowBox[{
        RowBox[{"x_", "/;", 
         RowBox[{"!", 
          RowBox[{"NumericQ", "[", "x", "]"}]}]}], ":>", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"ToExpression", "[", "x", "]"}], ",", "0"}], "]"}]}]}]}], 
      "}"}], ",", 
     RowBox[{"{", "1", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"titles", ",", "plays"}], "}"}], "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ">", "0"}], "&"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"titles", "=", 
   RowBox[{"data", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
