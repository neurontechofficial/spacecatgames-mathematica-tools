Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Published", " ", "CSV", " ", "link"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
    "sheetURL", 
     "=", "\"\<https://docs.google.com/spreadsheets/d/e/2PACX-1vTf-\
6AlCge2OKAs4JuAPi5cPtJWmGqjMy27zGyTheWlWiToV4MxwCel0E_YiMiK11QpF69v-EW8bi78/\
pub?output=csv\>\""}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Import", " ", "the", " ", "data"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Import", "[", 
      RowBox[{"sheetURL", ",", "\"\<CSV\>\""}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Separate", " ", "headers", " ", "and", " ", "values"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"values", "=", 
     RowBox[{"Rest", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Clean", " ", "and", " ", "convert", " ", "total", " ", "plays", " ", 
      "to", " ", "numbers"}], ",", 
     RowBox[{
      RowBox[{"replace", " ", 
       RowBox[{"missing", "/", "non"}]}], "-", 
      RowBox[{"numeric", " ", "with", " ", "0"}]}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"cleanValues", "=", 
     RowBox[{"values", "/.", " ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"title_", ",", "count_"}], "}"}], ":>", 
       RowBox[{"{", 
        RowBox[{"title", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"StringQ", "[", "count", "]"}], "&&", 
            RowBox[{"StringMatchQ", "[", 
             RowBox[{"count", ",", "NumberString"}], "]"}]}], ",", 
           RowBox[{"ToExpression", "[", "count", "]"}], ",", "0"}], "]"}]}], 
        "}"}]}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"sorted", "=", 
     RowBox[{"Reverse", "@", 
      RowBox[{"SortBy", "[", 
       RowBox[{"cleanValues", ",", "Last"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Tooltip", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"sorted", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"sorted", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "sorted", "]"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"PlotStyle", "->", "Red"}], ",", 
     RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Rank\>\"", ",", "\"\<Total Plays\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Game Plays by Rank\>\""}], ",", 
     RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.982413995276557*^9, 3.9824140905851517`*^9}, {
  3.982414139321594*^9, 3.982414349815363*^9}},
